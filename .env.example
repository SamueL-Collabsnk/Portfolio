# =============================================
# .env – Portfolio Backend Environment Variables
# RENAME THIS FILE to .env and fill in your values
# =============================================

# Port (default: 3000)
PORT=3000

# ---- Email Settings ----
# Service: 'gmail' | 'outlook' | 'yahoo' | 'hotmail'
EMAIL_SERVICE=gmail

# Your email address (the one that SENDS the notifications)
EMAIL_USER=your_email@gmail.com

# App Password (NOT your regular password!)
# Gmail: https://myaccount.google.com/apppasswords
# Outlook: https://account.microsoft.com/security
EMAIL_PASS=your_16_character_app_password

# The email address where contact form notifications are delivered
# Leave empty to use EMAIL_USER
OWNER_EMAIL=your_email@gmail.com

# Allowed origin for CORS (your deployed domain, e.g. https://samuelkimonge.com)
# Use * during local development only
ALLOWED_ORIGIN=*
